# ── Local development only ─────────────────────────────────────────────────
# In production (AWS), DB credentials come from Secrets Manager via DB_SECRET_ARN.
# Never commit a real .env file to version control.

# ── Server ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
SESSION_SECRET=change-this-to-a-long-random-string-in-production

# ── Database (local MySQL) ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=CampusBookingDB
DB_USER=root
DB_PASSWORD=YourLocalPassword123!
DB_SSL=false

# ── AWS (production only) ──────────────────────────────────────────────────
# DB_SECRET_ARN=arn:aws:secretsmanager:ap-southeast-1:123456789:secret:campus-booking/rds/credentials
# AWS_REGION=ap-southeast-1
